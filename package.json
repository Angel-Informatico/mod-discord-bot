{
  "name": "niby",
  "description": "A multipurpose Discord bot with a variety of features including music, moderation, and more.",
  "version": "1.1.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "dotenvx run -f .env.production -- node dist/index.js",
    "dev": "dotenvx run -f .env -- node dist/index.js",
    "clean": "rm -r dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "docker:build": "docker build -t niby-discord-bot -f docker/images/niby/Dockerfile .",
    "docker:run": "docker run -d --name niby-discord-bot --env-file .env -p 3000:3000 niby-discord-bot",
    "docker:logs": "docker logs -f niby-discord-bot",
    "docker:stop": "docker stop niby-discord-bot",
    "docker:rm": "docker rm niby-discord-bot"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.48.1",
    "@flytri/lyrics-finder": "^1.0.7",
    "@iamtraction/google-translate": "^2.0.1",
    "@parvineyvazov/json-translator": "^1.8.0",
    "@types/express": "^4.17.23",
    "@types/express-flash": "^0.0.2",
    "azlyrics-ext": "^1.0.1",
    "body-parser": "^1.20.2",
    "bufferutil": "^4.0.7",
    "colors": "^1.4.0",
    "connect-flash": "^0.1.1",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "cron": "^2.4.1",
    "discord-giveaways": "github:dewstouh/discord-giveaways",
    "discord-hybrid-sharding": "github:meister03/discord-hybrid-sharding",
    "discord.js": "^14.13.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^6.9.0",
    "express-session": "^1.17.3",
    "fast-glob": "^3.3.1",
    "http": "^0.0.1-security",
    "i18n": "^0.15.1",
    "js-azlyrics": "^0.2.4",
    "jsdom": "^22.1.0",
    "lavalink-client": "github:Tomato6966/lavalink-client",
    "lyrics-finder": "^21.7.0",
    "memorystore": "^1.6.7",
    "mongoose": "^7.5.0",
    "ms": "^2.1.3",
    "node-os-utils": "^1.3.7",
    "passport": "^0.6.0",
    "passport-discord": "^0.1.4",
    "redis": "^4.6.8",
    "socket.io": "^4.7.2",
    "speedgoose": "^2.1.0",
    "utf-8-validate": "^6.0.3",
    "zlib-sync": "^0.1.8"
  },
  "devDependencies": {
    "@types/express-session": "^1.17.7",
    "@types/i18n": "^0.13.6",
    "@types/ms": "^0.7.31",
    "@types/node": "^20.5.1",
    "@types/paypal-rest-sdk": "^1.7.6",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.1.6"
  }
}
