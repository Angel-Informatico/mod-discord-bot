{
  "name": "niby",
  "description": "A multipurpose Discord bot with a variety of features including music, moderation, and more.",
  "version": "1.1.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "dotenvx run -f .env.production -- node dist/index.js",
    "dev": "dotenvx run -f .env.local -- node dist/index.js",
    "clean": "rm -r dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "docker:build": "docker build -t niby-discord-bot -f docker/images/niby/Dockerfile .",
    "docker:run": "docker run -d --name niby-discord-bot --env-file .env -p 3000:3000 niby-discord-bot",
    "docker:restart": "docker restart niby-discord-bot",
    "docker:logs": "docker logs -f niby-discord-bot",
    "docker:stop": "docker stop niby-discord-bot",
    "docker:rm": "docker rm niby-discord-bot"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@flytri/lyrics-finder": "^1.0.7",
    "@iamtraction/google-translate": "^2.0.1",
    "@parvineyvazov/json-translator": "^4.1.0",
    "@types/express": "^5.0.6",
    "@types/express-flash": "^0.0.5",
    "azlyrics-ext": "^1.0.1",
    "body-parser": "^2.3.0",
    "colors": "^1.4.0",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cron": "^4.4.0",
    "discord-giveaways": "github:dewstouh/discord-giveaways",
    "discord-hybrid-sharding": "github:meister03/discord-hybrid-sharding",
    "discord.js": "^14.26.4",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "fast-glob": "^3.3.3",
    "http": "^0.0.1-security",
    "i18n": "^0.15.3",
    "js-azlyrics": "^0.2.4",
    "jsdom": "^29.1.1",
    "lavalink-client": "github:Tomato6966/lavalink-client",
    "lyrics-finder": "^21.7.0",
    "memorystore": "^1.6.8",
    "mongoose": "^9.7.2",
    "ms": "^2.1.3",
    "node-os-utils": "^1.3.7",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "speedgoose": "^2.5.8"
  },
  "devDependencies": {
    "@types/connect-flash": "^0.0.40",
    "@types/express-session": "^1.19.0",
    "@types/i18n": "^0.13.12",
    "@types/ms": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/paypal-rest-sdk": "^1.7.9",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
