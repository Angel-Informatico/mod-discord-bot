<%- include('../header') %>

<main class="othermain">
  <section class="otherhero">
    <div class="container">
    <!-- Header y Alertas -->
    <div class="row mb-4 mt-5 pt-3">
      <div class="col-12 text-center">
        <h1 class="display-4 fw-bold text-warning"><i class="bi bi-star-fill"></i> Panel Premium</h1>
        <p class="lead" style="color: var(--text-color);">Generador de Claves y Gestión de Suscripciones.</p>
        <div class="mt-3">
          <a href="/owner" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver al Panel</a>
        </div>
      </div>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Formulario para generar claves -->
    <div class="row mb-5 justify-content-center">
      <div class="col-md-8">
        <div class="card bg-dark text-light border-warning shadow">
          <div class="card-header border-warning bg-transparent text-center">
            <h4 class="mb-0 text-warning"><i class="bi bi-key-fill"></i> Generar Nueva Clave Premium</h4>
          </div>
          <div class="card-body">
            <form action="/owner/premium/generate" method="POST">
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="duration" class="form-label">Duración</label>
                  <input type="text" class="form-control border-0" style="background-color: var(--main-color); color: var(--text-color);" id="duration" name="duration" placeholder="Ej: 30d, 1y, infinite" required>
                  <div class="form-text" style="color: var(--light-gray);">Ejemplos: 10d (días), 2y (años), infinite (infinito)</div>
                </div>
                <div class="col-md-6">
                  <label for="type" class="form-label">Tipo de Clave</label>
                  <select class="form-select border-0" style="background-color: var(--main-color); color: var(--text-color);" id="type" name="type" required>
                    <option value="user">Usuario (Premium Global)</option>
                    <option value="guild">Servidor (Premium de Servidor)</option>
                  </select>
                </div>
                <div class="col-12 text-center mt-4">
                  <button type="submit" class="btn btn-warning px-5 fw-bold"><i class="bi bi-gear-fill me-2"></i> Generar Clave</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Claves sin reclamar -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card bg-dark text-light border-secondary">
          <div class="card-header border-secondary d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-key"></i> Claves Generadas (Sin Reclamar)</h4>
            <span class="badge bg-warning text-dark rounded-pill"><%= generatedKeys.length %> claves</span>
          </div>
          <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
            <div class="table-responsive">
              <table class="table table-dark table-hover table-borderless mb-0 align-middle text-center">
                <thead class="sticky-top" style="background-color: var(--dark-gray); color: var(--accent-color);">
                  <tr>
                    <th scope="col">Clave</th>
                    <th scope="col">Tipo</th>
                    <th scope="col">Duración (ms)</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (generatedKeys && generatedKeys.length > 0) { %>
                    <% generatedKeys.forEach(k => { %>
                      <tr>
                        <td class="font-monospace text-warning"><%= k.key %></td>
                        <td>
                          <% if (k.type === 'guild') { %>
                            <span class="badge bg-primary"><i class="bi bi-server"></i> Servidor</span>
                          <% } else { %>
                            <span class="badge bg-success"><i class="bi bi-person"></i> Usuario</span>
                          <% } %>
                        </td>
                        <td>
                            <% if (k.expiration > 315360000000) { %>
                                <span class="badge bg-danger">Infinito</span>
                            <% } else { %>
                                <%= Math.floor(k.expiration / 1000 / 60 / 60 / 24) %> días
                            <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="py-4" style="color: var(--light-gray);">No hay claves sin reclamar actualmente.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Usuarios Premium Activos -->
    <div class="row mb-4">
      <div class="col-12">
        <div class="card bg-dark text-light border-secondary">
          <div class="card-header border-secondary">
            <h4 class="mb-0"><i class="bi bi-people-fill text-success"></i> Usuarios Premium</h4>
          </div>
          <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
            <div class="table-responsive">
              <table class="table table-dark table-hover table-borderless mb-0 align-middle text-center">
                <thead class="sticky-top" style="background-color: var(--dark-gray); color: var(--accent-color);">
                  <tr>
                    <th scope="col" class="ps-4 text-start">Usuario</th>
                    <th scope="col">ID</th>
                    <th scope="col">Expiración</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (premiumUsers && premiumUsers.length > 0) { %>
                    <% premiumUsers.forEach(u => { %>
                      <tr>
                        <td class="ps-4 text-start">
                          <div class="d-flex align-items-center">
                            <% if (u.avatar) { %>
                              <img src="<%= u.avatar %>" alt="Avatar" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                            <% } else { %>
                              <div class="rounded-circle bg-secondary d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                <i class="bi bi-person text-light"></i>
                              </div>
                            <% } %>
                            <span class="fw-bold"><%= u.name %></span>
                          </div>
                        </td>
                        <td class="font-monospace" style="color: var(--light-gray);"><%= u.id %></td>
                        <td>
                          <% if (u.expiresAt > Date.now() + 315360000000) { %>
                              <span class="badge bg-danger">Permanente</span>
                          <% } else { %>
                              <%= new Date(u.expiresAt).toLocaleDateString() %>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="py-4" style="color: var(--light-gray);">No hay usuarios premium actualmente.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Servidores Premium Activos -->
    <div class="row mb-5">
      <div class="col-12">
        <div class="card bg-dark text-light border-secondary">
          <div class="card-header border-secondary">
            <h4 class="mb-0"><i class="bi bi-server text-primary"></i> Servidores Premium</h4>
          </div>
          <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
            <div class="table-responsive">
              <table class="table table-dark table-hover table-borderless mb-0 align-middle text-center">
                <thead class="sticky-top" style="background-color: var(--dark-gray); color: var(--accent-color);">
                  <tr>
                    <th scope="col" class="ps-4 text-start">Servidor</th>
                    <th scope="col">ID</th>
                    <th scope="col">Expiración</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (premiumGuilds && premiumGuilds.length > 0) { %>
                    <% premiumGuilds.forEach(g => { %>
                      <tr>
                        <td class="ps-4 text-start">
                          <div class="d-flex align-items-center">
                            <% if (g.icon) { %>
                              <img src="<%= g.icon %>" alt="Icono" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                            <% } else { %>
                              <div class="rounded-circle bg-secondary d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                <i class="bi bi-discord text-light"></i>
                              </div>
                            <% } %>
                            <span class="fw-bold"><%= g.name %></span>
                          </div>
                        </td>
                        <td class="font-monospace" style="color: var(--light-gray);"><%= g.id %></td>
                        <td>
                          <% if (g.expiresAt > Date.now() + 315360000000) { %>
                              <span class="badge bg-danger">Permanente</span>
                          <% } else { %>
                              <%= new Date(g.expiresAt).toLocaleDateString() %>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="py-4" style="color: var(--light-gray);">No hay servidores premium actualmente.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    </div>
  </section>
</main>

<%- include('../footer') %>
