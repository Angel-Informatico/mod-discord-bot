<%- include('../header') %>

<main class="othermain">
  <section class="otherhero">
    <div class="container">
    <div class="row mb-4 mt-5 pt-3">
      <div class="col-12 text-center">
        <h1 class="display-4 fw-bold" style="color: var(--accent-color);"><i class="bi bi-shield-lock"></i> Panel de Dueño</h1>
        <p class="lead" style="color: var(--text-color);">Bienvenido al centro de control absoluto del bot.</p>
      </div>
    </div>

    <!-- Estadísticas Generales -->
    <div class="row mb-5 text-center g-4 counts" style="padding: 0;">
      <div class="col-md-4">
        <div class="count-box">
          <i class="bi bi-server"></i>
          <div>
            <span style="font-size: 32px;"><%= totalGuilds %></span>
            <p style="font-size: 16px;">Servidores Totales</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="count-box">
          <i class="bi bi-people-fill"></i>
          <div>
            <span style="font-size: 32px;"><%= totalUsers.toLocaleString() %></span>
            <p style="font-size: 16px;">Usuarios Totales</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="count-box">
          <i class="bi bi-activity"></i>
          <div>
            <span style="font-size: 32px;"><%= ping %> ms</span>
            <p style="font-size: 16px;">Latencia (Ping)</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Navegación interna -->
    <div class="row mb-4">
        <div class="col-12 text-center">
            <a href="/owner/premium" class="btn btn-outline-warning btn-lg"><i class="bi bi-star-fill me-2"></i> Gestionar Premium</a>
        </div>
    </div>

    <!-- Lista de Servidores -->
    <div class="row">
      <div class="col-12">
        <div class="card bg-dark text-light border-secondary">
          <div class="card-header border-secondary d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-list-ul"></i> Lista de Servidores</h4>
            <span class="badge bg-primary rounded-pill"><%= guilds.length %> servers</span>
          </div>
          <div class="card-body p-0" style="max-height: 600px; overflow-y: auto;">
            <div class="table-responsive">
              <table class="table table-dark table-hover table-borderless mb-0 align-middle">
                <thead class="sticky-top" style="background-color: var(--dark-gray); color: var(--accent-color);">
                  <tr>
                    <th scope="col" class="ps-4">Servidor</th>
                    <th scope="col">ID</th>
                    <th scope="col" class="text-end pe-4">Miembros</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (guilds && guilds.length > 0) { %>
                    <% guilds.forEach(guild => { %>
                      <tr>
                        <td class="ps-4">
                          <div class="d-flex align-items-center">
                            <% if (guild.icon) { %>
                              <img src="<%= guild.icon %>" alt="Icono" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                            <% } else { %>
                              <div class="rounded-circle bg-secondary d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                <i class="bi bi-discord text-light"></i>
                              </div>
                            <% } %>
                            <span class="fw-bold"><%= guild.name %></span>
                          </div>
                        </td>
                        <td class="font-monospace" style="color: var(--light-gray);"><%= guild.id %></td>
                        <td class="text-end pe-4">
                          <span class="badge bg-secondary"><i class="bi bi-person-fill"></i> <%= guild.memberCount.toLocaleString() %></span>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="text-center py-4 text-muted">No hay servidores registrados.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    </div>
  </section>
</main>

<%- include('../footer') %>
